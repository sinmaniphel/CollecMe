{% extends 'CollecMeCollectionBundle::colme_layout.html.twig'%}

{% block content %}
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>login</th>
      <th>password</th>
      <th>email</th>
      <th>roles</th>
      <th>Ajouter rôles</th>
      <th>Supprimer</th>
    </tr>
  </thead>
  <tbody>
    {% for user in users %}
  <tr>
        <td>{{ user.user.login }}</td>
        <td>{{ user.user.password}}</td>
        <td>{{ user.user.email}}</td>
        <td>
        {% for role in user.roles %}
          <span class="label label-default">{{role}}</span>
        {% endfor %}
        </td>
        <td><a href="/user/roles/{{user.user.id}}" class="btn btn-success btn-xs">Ajouter</a></td>
        <td><a href="/user/delete/{{user.user.id}}" class="btn btn-danger btn-xs">Supprimer</a></td>
      </tr>
    {% endfor %}
</table>
{% endblock %}
