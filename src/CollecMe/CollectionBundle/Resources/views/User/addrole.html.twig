{% extends 'CollecMeCollectionBundle::colme_layout.html.twig'%}

{% block content %}
<div class="page-header">
        <h1>Ajout de rôles</h1>
        <p class="lead">Quels rôles souhaitez vous ajouter à l'utilisateur {{ user.login }} ?</p>
</div>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Role</th>
      <th>Description</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    {% for role in roles %}
      <tr>
        <td>{{ role.roleName }}</td>
        <td>{{ role.description}}</td>
        <td>
        {% if role.enabled %}
        <a href="/user/removeRole/{{user.login}}/{{role.roleName}}" class="btn btn-success btn-xs">Désactiver</a>

        {% else %}
        <a href="/user/addRole/{{user.login}}/{{role.roleName}}" class="btn btn-danger btn-xs">Désactivé</a>

        {% endif %}
        </td>

      </tr>
    {% endfor %}
</table>
{% endblock %}
