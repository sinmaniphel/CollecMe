{% extends 'CollecMeCollectionBundle::colme_layout.html.twig'%}

{% trans_default_domain "role" %}

{% block content %}
<div class="page-header">
        <h1>{% trans %}role.addToUser.title {% endtrans %}</h1>
        <p class="lead">{% trans %}role.addToUser.description {% endtrans %}Quels rôles souhaitez vous ajouter à l'utilisateur {{ user.login }} ?</p>
</div>
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>{% trans %}role.name {% endtrans %}</th>
      <th>{% trans %}role.description {% endtrans %}</th>
      <th>{% trans from "vague" %}vague.status{% endtrans %}</th>
    </tr>
  </thead>
  <tbody>
    {% for role in roles %}
      <tr>
        <td>{{ role.roleName }}</td>
        <td>{{ role.description}}</td>
        <td>
        {% if role.enabled %}
        <a href="/user/removeRole/{{user.login}}/{{role.roleName}}" class="btn btn-success btn-xs">{% trans from "action"%}action.toggle.off{% endtrans %}</a>

        {% else %}
        <a href="/user/addRole/{{user.login}}/{{role.roleName}}" class="btn btn-danger btn-xs">{% trans from "action"%}action.toggle.on{% endtrans %}</a>

        {% endif %}
        </td>

      </tr>
    {% endfor %}
</table>
{% endblock %}
