{% extends 'CollecMeCollectionBundle::colme_layout.html.twig'%}

{% block content %}
<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Nom rôle</th>
      <th>Description</th>
      <th>Supprimer</th>
    </tr>
  </thead>
  <tbody>
    {% for role in roles %}
      <tr>
        <td>{{ role.roleName }}</td>
        <td>{{ role.roleDescription}}</td>
        <td><a href="/role/delete/{{role.id}}/" class="btn btn-danger">Supprimer</a></td>
      </tr>
    {% endfor %}
    <tr>



    </tr>
</table>
<div class="row">
  <form class="form-horizontal" action="{{ path('role_add_route') }}" method="post">
  <div class="col-lg-4">
    <label for="roleName" class="sr-only">Role</label>
    <input class="form-control" id="roleName"
    placeholder="Nom de rôle" type="text" name="_roleName">
  </div>
  <div class="col-lg-6">
    <label for="roleDescription" class="sr-only">Description</label>
    <input class="form-control" id="roleDescription"
    placeholder="Description" type="text" name="_roleDescription">
  </div>
  <div class="col-lg-2">
    <button type="submit" class="btn btn-success">Ajouter</button>
  </div>
</form>

</div>

{% endblock %}
